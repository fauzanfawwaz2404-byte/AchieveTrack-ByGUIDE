rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userPermissions/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /kategori/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /promos/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /transaksi/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com' || (resource == null && request.resource != null));
    }
    match /driverWic/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /upaya/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com' || (resource == null && request.resource != null));
    }
