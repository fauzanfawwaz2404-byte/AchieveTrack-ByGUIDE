      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com' || (resource == null && request.resource != null));
    }
    match /waSetup/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /waTargets/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /waHistory/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /waCampaigns/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /waSetupCBG/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /waSetupsCBG/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
    }
    match /waTargetsCBG/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /waHistoryCBG/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /waCampaignsCBG/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == 'fauzanfawwaz2404@gmail.com';
